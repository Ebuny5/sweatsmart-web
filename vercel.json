
{
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://ujbcolxawpzfjkjviwqw.supabase.co/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(index.html|sw.js|manifest.json)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
